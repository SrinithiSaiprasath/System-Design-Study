    {
      "id": "nbqIWA2Aee8oy6dM0efCS",
      "type": "text",
      "x": 982.2481281280523,
      "y": 749.0110983954535,
      "width": 499.3793182373047,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
