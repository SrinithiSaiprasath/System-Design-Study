      "versionNonce": 1748013201,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776019284652,
      "link": null,
      "locked": false,
      "text": "POST : /api/urls/shorten    \nreq : Long URL\nres : Short URL\n\nGET : /api/urls{shorturl}\nreq : shortUrl\nres : redirected to long URL => 302",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "POST : /api/urls/shorten    \nreq : Long URL\nres : Short URL\n\nGET : /api/urls{shorturl}\nreq : shortUrl\nres : redirected to long URL => 302",
      "autoResize": false,
      "lineHeight": 1.25
    },
