    {
      "id": "yxyIwKFbH6654FSE5fGPp",
      "type": "text",
      "x": 1577.2481663134772,
      "y": 764.1684866144159,
      "width": 630.0197143554688,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aD",
      "roundness": null,
      "seed": 906868351,
      "version": 573,
      "versionNonce": 1877647185,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776016783143,
      "link": null,
      "locked": false,
      "text": "Consider: \n- 10 Million users generate URL per day\n- Length of URL : Len > 15 => len < 8\n- Allowed characters : a-z /  A-Z / @% / 1-9\n- URL cannot be updated / deleted\n- URL Redirection should be fast -> low latency\n- No of requests per day : 10*(10^6) * 20 => 200 Million => 2B \n- 2B Req per day / 3600 => 50 Req / sec",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Consider: \n- 10 Million users generate URL per day\n- Length of URL : Len > 15 => len < 8\n- Allowed characters : a-z /  A-Z / @% / 1-9\n- URL cannot be updated / deleted\n- URL Redirection should be fast -> low latency\n- No of requests per day : 10*(10^6) * 20 => 200 Million => 2B \n- 2B Req per day / 3600 => 50 Req / sec",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-21T2evzhw0O3kwEZoJMs",
      "type": "text",
      "x": 1537.2295270284014,
      "y": 1383.3112761815394,
      "width": 383.21316867404505,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
